COMPOSE_PROJECT_NAME=llama-stack

# Absolute or relative path on the host/WSL filesystem where GGUF files live.
# Default points to the current external location of the existing GGUF file.
MODEL_DIR=/path/to/models
MODEL_FILE=Qwen3.5-35B-A3B-Q4_K_M.gguf

# Public port for the OpenAI-compatible proxy.
PROXY_PORT=8000

# Internal llama.cpp server port published to host for direct debugging.
LLAMA_SERVER_PORT=8001
LLAMA_SERVER_PUBLIC_PORT=8001

# Docker build versions.
CUDA_VERSION=12.4.0
UBUNTU_VERSION=22.04
LLAMA_CPP_REPO=https://github.com/ggml-org/llama.cpp.git
LLAMA_CPP_REF=c1b911654a581662c19eb51829705e4ed7020673

# Your GPU Cuda Arch
CUDA_ARCH=90

# Runtime policy: required | fallback
LLAMA_GPU_MODE=required

# Container user-facing identity.
LLAMA_MODEL_ALIAS=Qwen3.5-35B-A3B

# Server/proxy logging.
LLAMA_LOG_LEVEL=INFO
PROXY_LOG_LEVEL=INFO
